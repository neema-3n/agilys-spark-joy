{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "type": "module",
  "scripts": {
    "preinstall": "node -e \"const ua=process.env.npm_config_user_agent||''; if(!ua.includes('pnpm')){console.error('This repository uses pnpm. Run: corepack enable && pnpm install'); process.exit(1)}\"",
    "dev": "bash ./scripts/dev.sh",
    "dev:frontend": "vite",
    "dev:backend": "pnpm --dir backend run start:dev",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "pnpm --dir backend run build",
    "build:dev": "vite build --mode development",
    "lint": "pnpm run lint:frontend && pnpm run lint:backend",
    "lint:frontend": "eslint .",
    "lint:backend": "pnpm --dir backend run lint",
    "test": "pnpm run test:frontend && pnpm run test:backend",
    "test:dev-command": "bash ./tests/dev-command.test.sh",
    "test:frontend": "pnpm exec playwright test tests/auth-migration.spec.ts",
    "test:backend": "pnpm --dir backend run test",
    "preview": "vite preview",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:reset": "bash ./scripts/db-reset.sh",
    "db:seed": "bash ./scripts/db-seed.sh",
    "db:verify": "bash ./scripts/verify-db-workflow.sh",
    "db:import:remote": "bash ./scripts/db-import-remote.sh",
    "db:snapshot:local": "bash ./scripts/db-snapshot-local.sh",
    "test:e2e:migration": "pnpm exec playwright test --config playwright.migration.config.ts --grep @migration-",
    "test:e2e:migration:gate": "node ./scripts/migration-e2e-gate.mjs",
    "test:rollback:gate": "node ./scripts/rollback-drill-gate.mjs",
    "test:supabase:runtime-gate": "node ./scripts/supabase-runtime-gate.mjs",
    "test:hypercare:gate": "node ./scripts/hypercare-gate.mjs"
  },
  "dependencies": {
