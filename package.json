  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.45.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
