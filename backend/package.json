{
  "name": "agilys-auth-api",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --runInBand",
    "test:contracts": "jest --runInBand src/contracts/contract-parity.spec.ts src/contracts/live-contract-parity.spec.ts",
    "test:contracts:live": "jest --runInBand src/contracts/live-contract-parity.spec.ts",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "migrate:lot-b": "ts-node src/migration/lot-b/cli.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
